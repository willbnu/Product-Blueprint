{
    "$schema": "http://json-schema.org/schema",
    "cli": "nx",
    "id": "prd",
    "title": "PRD Generator",
    "description": "Generate a PRD structure for a new project",
    "type": "object",
    "properties": {
        "name": {
            "type": "string",
            "description": "The name of the project",
            "$default": {
                "$source": "argv",
                "index": 0
            },
            "x-prompt": "What is the name of your project?"
        }
    },
    "required": [
        "name"
    ]
}