{
  "version": "1.0",
  "description": "TOON (Token-Oriented Object Notation) configuration for agent-optimized repository access",
  "compression": {
    "enabled": true,
    "level": "aggressive",
    "strategies": {
      "markdown": {
        "removeVerboseExplanations": true,
        "compressCodeComments": true,
        "extractKeyPoints": true,
        "maxTokensPerSection": 100,
        "preserveCodeBlocks": "minimal"
      },
      "code": {
        "removeComments": true,
        "preserveStructure": true,
        "minimalExamples": true
      }
    }
  },
  "generation": {
    "include": [
      "docs/**/*.md",
      "README.md",
      "CONTRIBUTING.md",
      "ARCHITECTURE.md",
      "SETUP.md",
      "GETTING_STARTED.md",
      "prd/**/*.md",
      "design-system/**/*.md"
    ],
    "exclude": [
      "node_modules/**",
      ".git/**",
      "**/*.test.md",
      "**/.DS_Store",
      ".toon/**"
    ],
    "priority": [
      "docs/API.md",
      "docs/MOBILE.md",
      "docs/WEB.md",
      "docs/BACKEND.md",
      "docs/CICD.md",
      "README.md",
      "ARCHITECTURE.md"
    ]
  },
  "cache": {
    "enabled": true,
    "invalidateOnChange": true,
    "ttl": null,
    "hashAlgorithm": "sha256"
  },
  "output": {
    "format": "json",
    "prettyPrint": false,
    "includeMetadata": true,
    "includeStats": true
  },
  "tokenCounting": {
    "model": "claude-sonnet-4",
    "estimationMethod": "tiktoken"
  }
}
