{
  "name": "product-blueprint",
  "version": "2.2.0",
  "description": "Production-ready full-stack application blueprint with working Expo mobile app and React web app. Features TanStack Router, shared libraries, Supabase backend, and comprehensive documentation.",
  "private": true,
  "scripts": {
    "docs:dev": "pnpm --filter product-blueprint-docs docs:dev",
    "docs:build": "pnpm --filter product-blueprint-docs docs:build",
    "docs:preview": "pnpm --filter product-blueprint-docs docs:preview",
    "portfolio:dev": "pnpm --filter @pb/portfolio dev",
    "portfolio:build": "pnpm --filter @pb/portfolio build",
    "portfolio:preview": "pnpm --filter @pb/portfolio preview"
  },
  "keywords": [
    "blueprint",
    "template",
    "monorepo",
    "expo",
    "react",
    "typescript",
    "tanstack-router",
    "supabase",
    "vite",
    "react-native",
    "zustand",
    "tailwindcss",
    "nativewind",
    "nx"
  ],
