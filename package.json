{
  "name": "chatgpt-workspace-blueprint",
  "version": "0.1.0",
  "description": "Production-ready full-stack app template blueprint with comprehensive documentation",
  "private": true,
  "scripts": {
    "toon:generate": "node tools/toon/generate-all.js",
    "toon:convert": "node tools/toon/converter.js",
    "toon:stats": "cat .toon/stats.json | json_pp",
    "toon:clean": "rm -rf .toon/docs .toon/stats.json .toon/manifest.json",
    "toon:watch": "nodemon --watch 'docs/**/*.md' --watch 'README.md' --exec 'npm run toon:generate'"
  },
  "keywords": [
    "blueprint",
    "template",
    "documentation",
    "architecture",
    "expo",
    "react",
    "supabase",
    "nx-monorepo"
  ],
  "author": "William Finger <https://github.com/willbnu>",
  "license": "MIT",
  "devDependencies": {
    "nodemon": "^3.0.0"
  }
}
