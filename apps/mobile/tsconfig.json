{
    "compilerOptions": {
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ],
            "@app/shared": [
                "../../libs/shared/src"
            ]
        },
        "jsx": "react-native",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "extends": "expo/tsconfig.base",
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".expo/types/**/*.ts",
        "expo-env.d.ts"
    ]
}