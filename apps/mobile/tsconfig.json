{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
        "strict": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["./*"],
            "@pb/shared": ["../../libs/shared/src"],
            "@pb/data": ["../../libs/data/src"],
            "@pb/state": ["../../libs/state/src"],
            "@app/shared": ["../../libs/shared/src"]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.tsx",
        ".expo/types/**/*.ts",
        "expo-env.d.ts"
    ]
}